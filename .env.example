# ============================================================
# GameHost Platform - Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ---------- General ----------
NODE_ENV=production
APP_NAME=GameHost
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# ---------- Database ----------
DB_USER=gamehost
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=gamehost
DB_PORT=5432
DATABASE_URL=postgresql://gamehost:CHANGE_ME_DB_PASSWORD@postgres:5432/gamehost?schema=public

# ---------- Redis ----------
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# ---------- JWT / Session ----------
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRY=7d
SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# ---------- Ports ----------
BACKEND_PORT=4000
FRONTEND_PORT=3000

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ---------- Discord OAuth ----------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:4000/api/auth/discord/callback

# ---------- Pterodactyl Panel ----------
PTERODACTYL_URL=https://panel.example.com
PTERODACTYL_APP_KEY=
PTERODACTYL_CLIENT_KEY=

# ---------- Razorpay ----------
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------- Cashfree ----------
CASHFREE_ENABLED=false
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox
CASHFREE_WEBHOOK_SECRET=

# ---------- UPI Manual Payment ----------
UPI_ENABLED=false
UPI_ID=yourname@upi
UPI_QR_URL=

# ---------- Datalix VPS ----------
DATALIX_ENABLED=false
DATALIX_API_KEY=
DATALIX_API_URL=https://backend.datalix.de/v1
DATALIX_KVM_LINE=intelxeon # ampepyc

# ---------- Discord Bot (Optional) ----------
DISCORD_BOT_TOKEN=
DISCORD_LOG_CHANNEL_ID=
DISCORD_ALERT_CHANNEL_ID=
DISCORD_GUILD_ID=

# ---------- Currency ----------
CURRENCY_SYMBOL=₹

# ---------- Ads / Credits ----------
FREE_CREDITS_TIMER_SECONDS=60
FREE_CREDITS_REWARD=10
FREE_SERVER_DELETE_DAYS=7
ADSENSE_PUBLISHER_ID=
# Multiple Adsterra script URLs (comma-separated) for maximum ad revenue
# Get these from Adsterra dashboard → Direct Link / Banner / Popunder scripts
ADSTERRA_SCRIPT_URLS=
# Legacy single URL (still works, use ADSTERRA_SCRIPT_URLS for multiple)
ADSTERRA_SCRIPT_URL=

# ---------- Cloudflare DNS (Optional) ----------
CLOUDFLARE_ENABLED=false
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_BASE_DOMAIN=play.gamehost.com

# ---------- Paymenter Billing (Optional) ----------
PAYMENTER_ENABLED=false
PAYMENTER_URL=https://billing.example.com
PAYMENTER_API_KEY=

# ---------- Frontend ----------
# Leave EMPTY to use Nginx (recommended). Frontend will use relative URLs.
# Only set this if your backend runs on a different host/port.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_NAME=GameHost

# ---------- SMTP / Email (Optional) ----------
# Required for email login/signup, verification, and password reset.
# If not configured, emails will be logged to console (dev mode).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gamehost.com

# ---------- Backup (Optional) ----------
# GPG passphrase for encrypted backups (bash backup.sh --encrypt)
GPG_PASSPHRASE=
# Remote backup destination (bash backup.sh --remote)
BACKUP_REMOTE_HOST=
BACKUP_REMOTE_USER=root
BACKUP_REMOTE_PATH=/opt/backups/gamehost
