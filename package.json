{
  "name": "gamehost-platform",
  "version": "1.0.0",
  "private": true,
  "description": "GameHost — Game Server Hosting Platform",
  "scripts": {
    "install": "bash install.sh",
    "update": "bash update.sh",
    "restart": "bash restart.sh",
    "backup": "bash backup.sh",
    "logs": "docker compose logs -f",
    "logs:backend": "docker compose logs -f backend",
    "logs:frontend": "docker compose logs -f frontend",
    "status": "docker compose ps",
    "build": "docker compose build",
    "build:no-cache": "docker compose build --no-cache",
    "up": "docker compose up -d",
    "down": "docker compose down",
    "typecheck:backend": "cd backend && npx tsc --noEmit",
    "typecheck:frontend": "cd frontend && npx tsc --noEmit",
    "validate": "npm run typecheck:backend && npm run typecheck:frontend",
    "prisma:migrate": "docker compose exec backend npx prisma migrate deploy",
    "prisma:studio": "cd backend && npx prisma studio",
    "health": "curl -s http://localhost:${BACKEND_PORT:-4000}/api/health | head -c 500"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  }
}
